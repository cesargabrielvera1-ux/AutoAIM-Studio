# ==========================================
# AutoAIM Studio - Git Ignore Configuration
# ==========================================

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.manifest
*.spec

# ----- Virtual Environments -----
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/
.env/
environment.yml
Pipfile.lock

# ----- PyInstaller Specific -----
# Usually these files are written by a python script from a template
# before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# PyInstaller dist/build folders (if you compile locally)
build/
dist/
_output/
*.exe
*.app
*.dmg

# ----- IDEs and Editors -----
# VS Code
.vscode/
*.code-workspace
.history/

# PyCharm
.idea/
*.iml
*.iws
*.ipynb_checkpoints/

# Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace
*.sublime-project

# ----- OS Generated Files -----
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Linux
*~
.nfs*

# ----- Model Files and Data (Large Binaries) -----
# Do not commit trained models (users generate these)
*.joblib
*.pkl
*.pickle
*.pt
*.pth
*.h5
*.hdf5
*.onnx
model_weights/
models/saved/
*.safetensors

# Large datasets
*.csv
*.xlsx
*.xls
!examples/sample_data.csv  # Keep only the example dataset

# ----- Logs and Databases -----
*.log
*.sql
*.sqlite
*.sqlite3
logs/
log/

# ----- Environment and Secrets -----
.env
.env.local
.env.*.local
!.env.example
secrets.json
credentials.json
api_keys.txt

