htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# ----- Documentation Builds -----
docs/_build/
site/

# ----- Jupyter Notebooks (if any) -----
.ipynb_checkpoints
*.ipynb

